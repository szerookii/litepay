DATABASE_URL=postgres://litepay:CHANGE_ME@postgres:5432/litepay

POSTGRES_PASSWORD=CHANGE_ME

JWT_SECRET=change-me-to-a-random-secret-of-at-least-32-chars

# Enable/disable new user registration
ALLOW_REGISTER=true

# Secret provider for the master seed: env (default), vault, bitwarden, aws, gcp
# See README for when to use each one.
SECRET_PROVIDER=env

# env
MASTER_SEED=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# vault
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=
# VAULT_MOUNT=secret
# VAULT_PATH=litepay
# VAULT_KEY=master_seed

# bitwarden
# BITWARDEN_CLIENT_ID=
# BITWARDEN_CLIENT_SECRET=
# BITWARDEN_SECRET_ID=
# BITWARDEN_IDENTITY_URL=https://identity.bitwarden.com
# BITWARDEN_API_URL=https://api.bitwarden.com

# aws
# AWS_REGION=us-east-1
# AWS_SECRET_ID=litepay/master_seed
# AWS_SECRET_KEY=master_seed
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# gcp
# GCP_PROJECT_ID=my-project
# GCP_SECRET_NAME=litepay-master-seed
# GCP_SECRET_VERSION=latest
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

BTC_RPC_URL=https://lb.drpc.live/bitcoin/YOUR_KEY
LTC_RPC_URL=https://lb.drpc.live/litecoin/YOUR_KEY
SOL_RPC_URL=https://api.mainnet.solana.com
