# Database (matches docker-compose.dev.yml)
DATABASE_URL=postgres://litepay:litepay@localhost:5432/litepay
ATLAS_DATABASE_URL=postgres://litepay:litepay@localhost:5433/litepay_dev

# JWT
JWT_SECRET=change-me-to-a-random-secret

# Master HD wallet seed (BIP39 mnemonic — 12 or 24 words)
# Generate: `openssl rand -hex 32` then use a BIP39 tool, or use a hardware wallet seed
# KEEP THIS SECRET — controls all user wallets across all coins
MASTER_SEED=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# dRPC endpoints (https://drpc.org)
# Format: https://lb.drpc.live/{network}/{YOUR_KEY}
BTC_RPC_URL=https://lb.drpc.live/bitcoin/YOUR_KEY
LTC_RPC_URL=https://lb.drpc.live/litecoin/YOUR_KEY
SOL_RPC_URL=https://lb.drpc.live/solana/YOUR_KEY
